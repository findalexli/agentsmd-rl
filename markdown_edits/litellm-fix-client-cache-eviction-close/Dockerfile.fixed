FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git curl ca-certificates build-essential tmux && \
    rm -rf /var/lib/apt/lists/*

# Install litellm from PyPI to resolve all dependencies,
# then override with the cloned source at the base commit.
RUN pip install --no-cache-dir litellm pytest pytest-asyncio ruff black

# Clone repo at base commit
RUN git clone --filter=blob:none https://github.com/BerriAI/litellm.git /workspace/litellm && \
    cd /workspace/litellm && \
    git checkout bf9c96b91205d17e13d9c7ea54d396005db5bc63 && \
    git config user.email "agent@test" && \
    git config user.name "Agent"

WORKDIR /workspace/litellm

# Override pip-installed litellm with cloned source at base commit
ENV PYTHONPATH="/workspace/litellm:$PYTHONPATH"

# Verifier output directory (Harbor bind-mounts this)
RUN mkdir -p /logs/verifier

COPY tests/ /tests/
