FROM eclipse-temurin:17.0.12_7-jdk-jammy

ARG SELENIUM_BASE=36fc8f9b7bdedeba3884fadc232aec76fcd044c1

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        curl \
        patch \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pytest==8.3.4

RUN mkdir -p /opt/libs && cd /opt/libs && \
    curl -sSLo junit-platform-console-standalone.jar \
      https://repo1.maven.org/maven2/org/junit/platform/junit-platform-console-standalone/1.10.3/junit-platform-console-standalone-1.10.3.jar && \
    curl -sSLo assertj-core.jar \
      https://repo1.maven.org/maven2/org/assertj/assertj-core/3.26.3/assertj-core-3.26.3.jar

# Selenium repo files at base commit (only the paths affected by PR #17257)
RUN mkdir -p /workspace/selenium/java/src/org/openqa/selenium/io \
             /workspace/selenium/java/src/org/openqa/selenium/devtools/events \
             /workspace/selenium/java/src/org/openqa/selenium/remote/codec/w3c \
             /workspace/selenium/java/test/org/openqa/selenium/io

RUN cd /workspace/selenium && \
    curl -sSLo java/src/org/openqa/selenium/io/Read.java \
      "https://raw.githubusercontent.com/SeleniumHQ/selenium/${SELENIUM_BASE}/java/src/org/openqa/selenium/io/Read.java" && \
    curl -sSLo java/test/org/openqa/selenium/io/ReadTest.java \
      "https://raw.githubusercontent.com/SeleniumHQ/selenium/${SELENIUM_BASE}/java/test/org/openqa/selenium/io/ReadTest.java" && \
    curl -sSLo java/src/org/openqa/selenium/devtools/events/CdpEventTypes.java \
      "https://raw.githubusercontent.com/SeleniumHQ/selenium/${SELENIUM_BASE}/java/src/org/openqa/selenium/devtools/events/CdpEventTypes.java" && \
    curl -sSLo java/src/org/openqa/selenium/remote/RemoteScript.java \
      "https://raw.githubusercontent.com/SeleniumHQ/selenium/${SELENIUM_BASE}/java/src/org/openqa/selenium/remote/RemoteScript.java" && \
    curl -sSLo java/src/org/openqa/selenium/remote/codec/w3c/W3CHttpCommandCodec.java \
      "https://raw.githubusercontent.com/SeleniumHQ/selenium/${SELENIUM_BASE}/java/src/org/openqa/selenium/remote/codec/w3c/W3CHttpCommandCodec.java"

# Test resource fixture (the real isDisplayed.js is generated by Bazel from
# javascript/atoms/fragments; we plant a stand-in so upstream ReadTest can
# locate the resource without a full Bazel build).
RUN mkdir -p /workspace/test-resources/org/openqa/selenium/remote && \
    printf '%s\n' '/* selenium-test-fixture isDisplayed.js */' \
                  'function(){ return true; }' \
        > /workspace/test-resources/org/openqa/selenium/remote/isDisplayed.js

WORKDIR /workspace/selenium

RUN mkdir -p /logs/verifier
