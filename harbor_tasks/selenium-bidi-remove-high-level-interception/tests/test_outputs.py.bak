"""
Tests for Selenium .NET BiDi network interception API removal.

This validates that the high-level interception methods have been properly removed
and that the API surface matches the expected post-refactoring state.
"""

import subprocess
import os
import sys

REPO = "/workspace/selenium"
DOTNET_SRC = os.path.join(REPO, "dotnet/src/webdriver/BiDi")


def run_dotnet_code(code: str, cwd: str = None) -> tuple[int, str, str]:
    """Run C# code using dotnet run with a temporary project."""
    import tempfile
    import shutil

    tmpdir = tempfile.mkdtemp()
    try:
        # Create a minimal console project
        subprocess.run(
            ["dotnet", "new", "console", "-n", "TestProject", "-o", tmpdir],
            capture_output=True,
            cwd=tmpdir,
            check=True,
        )

        # Add reference to the webdriver project
        webdriver_proj = os.path.join(REPO, "dotnet/src/webdriver/WebDriver.csproj")
        subprocess.run(
            ["dotnet", "add", "reference", webdriver_proj],
            capture_output=True,
            cwd=os.path.join(tmpdir, "TestProject"),
            check=True,
        )

        # Write the test code
        with open(os.path.join(tmpdir, "TestProject", "Program.cs"), "w") as f:
            f.write(code)

        # Run the code
        result = subprocess.run(
            ["dotnet", "run"],
            capture_output=True,
            cwd=os.path.join(tmpdir, "TestProject"),
            timeout=60,
        )

        return result.returncode, result.stdout.decode(), result.stderr.decode()
    finally:
        shutil.rmtree(tmpdir)


def test_high_level_methods_removed_from_interface():
    """F2P: InterceptRequestAsync/InterceptResponseAsync/InterceptAuthAsync should NOT exist on INetworkModule."""
    code = '''
using OpenQA.Selenium.BiDi.Network;

// This should NOT compile if methods were removed
var methods = typeof(INetworkModule).GetMethods();
foreach (var m in methods)
{
    if (m.Name.Contains("InterceptRequest") || m.Name.Contains("InterceptResponse") || m.Name.Contains("InterceptAuth"))
    {
        System.Console.WriteLine("FAIL: Found method: " + m.Name);
        Environment.Exit(1);
    }
}
System.Console.WriteLine("PASS: High-level interception methods not found in interface");
'''
    returncode, stdout, stderr = run_dotnet_code(code)

    combined = stdout + stderr
    assert "PASS" in combined or returncode != 0, f"Expected methods to be removed, but got: {combined}"
    assert "FAIL" not in combined, f"High-level methods still exist in interface: {combined}"


def test_high_level_methods_removed_from_browsingcontext():
    """F2P: InterceptRequestAsync/InterceptResponseAsync/InterceptAuthAsync should NOT exist on IBrowsingContextNetworkModule."""
    code = '''
using OpenQA.Selenium.BiDi.BrowsingContext;

var methods = typeof(IBrowsingContextNetworkModule).GetMethods();
foreach (var m in methods)
{
    if (m.Name.Contains("InterceptRequest") || m.Name.Contains("InterceptResponse") || m.Name.Contains("InterceptAuth"))
    {
        System.Console.WriteLine("FAIL: Found method: " + m.Name);
        Environment.Exit(1);
    }
}
System.Console.WriteLine("PASS: High-level interception methods not found in browsing context interface");
'''
    returncode, stdout, stderr = run_dotnet_code(code)

    combined = stdout + stderr
    assert "PASS" in combined or returncode == 0, f"Expected methods to be removed: {combined}"
    assert "FAIL" not in combined, f"High-level methods still exist in browsing context: {combined}"


def test_high_level_file_deleted():
    """F2P: NetworkModule.HighLevel.cs should be deleted."""
    high_level_file = os.path.join(REPO, "dotnet/src/webdriver/BiDi/Network/NetworkModule.HighLevel.cs")
    assert not os.path.exists(high_level_file), f"NetworkModule.HighLevel.cs should be deleted but exists at {high_level_file}"


def test_add_intercept_async_exists():
    """P2P: AddInterceptAsync should still exist as the replacement API."""
    code = '''
using OpenQA.Selenium.BiDi.Network;

var method = typeof(INetworkModule).GetMethod("AddInterceptAsync");
if (method == null)
{
    System.Console.WriteLine("FAIL: AddInterceptAsync not found");
    Environment.Exit(1);
}
System.Console.WriteLine("PASS: AddInterceptAsync exists");
'''
    returncode, stdout, stderr = run_dotnet_code(code)

    combined = stdout + stderr
    assert "PASS" in combined, f"AddInterceptAsync should exist: {combined}"


def test_event_subscription_methods_exist():
    """P2P: Event subscription methods should still exist."""
    code = '''
using OpenQA.Selenium.BiDi.Network;

var methods = typeof(INetworkModule).GetMethods();
var onBeforeRequestSent = methods.Any(m => m.Name == "OnBeforeRequestSentAsync");
var onResponseStarted = methods.Any(m => m.Name == "OnResponseStartedAsync");
var onAuthRequired = methods.Any(m => m.Name == "OnAuthRequiredAsync");

if (!onBeforeRequestSent || !onResponseStarted || !onAuthRequired)
{
    System.Console.WriteLine("FAIL: Missing event subscription methods");
    Environment.Exit(1);
}
System.Console.WriteLine("PASS: Event subscription methods exist");
'''
    returncode, stdout, stderr = run_dotnet_code(code)

    combined = stdout + stderr
    assert "PASS" in combined, f"Event subscription methods should exist: {combined}"


def test_project_compiles():
    """F2P: The dotnet project should compile without the high-level file."""
    webdriver_proj = os.path.join(REPO, "dotnet/src/webdriver/WebDriver.csproj")

    result = subprocess.run(
        ["dotnet", "build", webdriver_proj, "--no-restore", "-v", "q"],
        capture_output=True,
        cwd=REPO,
        timeout=120,
    )

    stderr = result.stderr.decode()
    assert result.returncode == 0, f"Project should compile but got errors: {stderr}"


def test_intercept_options_types_removed():
    """F2P: InterceptRequestOptions, InterceptResponseOptions, InterceptAuthOptions should be removed."""
    code = '''
using System.Reflection;
using OpenQA.Selenium.BiDi.BrowsingContext;

var assembly = typeof(BrowsingContext).Assembly;
var types = assembly.GetTypes();

foreach (var t in types)
{
    var name = t.Name;
    if (name == "InterceptRequestOptions" || name == "InterceptResponseOptions" || name == "InterceptAuthOptions")
    {
        System.Console.WriteLine("FAIL: Found type that should be removed: " + name);
        Environment.Exit(1);
    }
}
System.Console.WriteLine("PASS: Intercept options types removed");
'''
    returncode, stdout, stderr = run_dotnet_code(code)

    combined = stdout + stderr
    # If compilation fails due to missing types, that's also a pass (types removed)
    if "InterceptRequestOptions" in stderr or "InterceptResponseOptions" in stderr or "InterceptAuthOptions" in stderr:
        # Types don't exist, which is what we want
        return

    assert "PASS" in combined or returncode == 0, f"Expected types to be removed: {combined}"
    assert "FAIL" not in combined, f"Types still exist: {combined}"


def test_intercepted_event_types_removed():
    """F2P: InterceptedRequest, InterceptedResponse, InterceptedAuth, Interception should be removed."""
    code = '''
using System.Reflection;
using OpenQA.Selenium.BiDi.BrowsingContext;

var assembly = typeof(BrowsingContext).Assembly;
var types = assembly.GetTypes();

foreach (var t in types)
{
    var name = t.Name;
    if (name == "InterceptedRequest" || name == "InterceptedResponse" || name == "InterceptedAuth" || name == "Interception")
    {
        System.Console.WriteLine("FAIL: Found type that should be removed: " + name);
        Environment.Exit(1);
    }
}
System.Console.WriteLine("PASS: Intercepted event types removed");
'''
    returncode, stdout, stderr = run_dotnet_code(code)

    combined = stdout + stderr
    # Check for compilation errors mentioning the removed types
    removed_types = ["InterceptedRequest", "InterceptedResponse", "InterceptedAuth", "Interception"]
    if any(t in stderr for t in removed_types):
        return

    assert "PASS" in combined or returncode == 0, f"Expected types to be removed: {combined}"
    assert "FAIL" not in combined, f"Types still exist: {combined}"
