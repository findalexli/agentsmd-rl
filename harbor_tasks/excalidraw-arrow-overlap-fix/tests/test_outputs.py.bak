def test_repo_typecheck():
    """Repo's TypeScript typecheck passes (pass_to_pass).

    Runs `yarn test:typecheck` which executes `tsc` to verify TypeScript
    compiles without errors. This is part of the repo's CI pipeline.
    """
    r = subprocess.run(
        ["yarn", "test:typecheck"],
        cwd=REPO,
        capture_output=True,
        text=True,
        timeout=180
    )
    print("Typecheck STDOUT:", r.stdout[-1000:] if len(r.stdout) > 1000 else r.stdout)
    print("Typecheck STDERR:", r.stderr[-1000:] if len(r.stderr) > 1000 else r.stderr)
    assert r.returncode == 0, f"TypeScript typecheck failed:\n{r.stderr[-500:]}"


