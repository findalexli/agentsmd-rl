        "App.tsx should not reference indirectArrowUpdate"


def test_linearElementEditor_no_customIntersector():
    """Test that linearElementEditor.ts no longer uses customIntersector"""
    editor_file = os.path.join(REPO, "packages/element/src/linearElementEditor.ts")
    with open(editor_file, "r") as f:
        content = f.read()

    # The fix removes customIntersector usage
    assert "customIntersector" not in content, \
        "linearElementEditor.ts should not reference customIntersector"


def test_focus_ts_passes_true_for_dragging():
    """Test that focus.ts passes true as dragging parameter"""
    focus_file = os.path.join(REPO, "packages/element/src/arrows/focus.ts")
    with open(focus_file, "r") as f:
        content = f.read()

    # After updateBoundPoint call, there should be a 'true' argument added
    # Look for the pattern of updateBoundPoint call with the extra true argument
    assert "updateBoundPoint(" in content, "updateBoundPoint should be called in focus.ts"

    # The fix adds 'true' as the last argument to one of the updateBoundPoint calls
    # This is in the focusPointUpdate function
    pattern_section = content[content.find("focusPointUpdate"):content.find("focusPointUpdate") + 2000]
    # Should have true added as parameter after elementsMap in the call
    if "true," not in pattern_section and ", true" not in pattern_section:
        # Check if it's at the end without comma
        pass  # The true might be formatted differently


def test_utils_ts_uses_opposite_focus_point():
    """Test that utils.ts uses opposite focus point for projection"""
    utils_file = os.path.join(REPO, "packages/element/src/utils.ts")
    with open(utils_file, "r") as f:
        content = f.read()

    # The fix adds imports for getGlobalFixedPointForBindableElement and normalizeFixedPoint
    assert "getGlobalFixedPointForBindableElement" in content, \
        "utils.ts should import getGlobalFixedPointForBindableElement"
    assert "normalizeFixedPoint" in content, \
        "utils.ts should import normalizeFixedPoint"

    # The fix adds logic to use opposite focus point when arrow has only 2 points
    assert "otherFocusPoint" in content, \
        "utils.ts should reference otherFocusPoint"
    assert "avoid working with stale arrow state" in content or \
           "opposite focus point" in content.lower(), \
        "Comment about stale state fix should be present"


