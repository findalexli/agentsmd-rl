"""Tests for arrow overlap behavior fix.

This test suite verifies the fix for arrow binding behavior when arrows overlap
with the elements they connect to. The key behavioral changes are:

1. BASE_ARROW_MIN_LENGTH constant should be exported (value = 10)
2. updateBoundPoint function signature should change to accept dragging parameter
3. extractBinding helper function should be implemented
4. updateBoundElements should no longer accept indirectArrowUpdate option
"""

import subprocess
import sys
import os

REPO = "/workspace/excalidraw"


def test_base_arrow_min_length_constant_exists():
    """Test that BASE_ARROW_MIN_LENGTH constant is exported from binding.ts"""
    # This is a f2p test - the constant is added in the fix
    code = """
import { BASE_ARROW_MIN_LENGTH } from "@excalidraw/element/binding";
console.log("BASE_ARROW_MIN_LENGTH:", BASE_ARROW_MIN_LENGTH);
if (BASE_ARROW_MIN_LENGTH !== 10) {
    console.error("Expected 10, got", BASE_ARROW_MIN_LENGTH);
    process.exit(1);
}
console.log("PASS: BASE_ARROW_MIN_LENGTH is correctly defined as 10");
"""
    result = subprocess.run(
        ["node", "-e", code],
        cwd=REPO,
        capture_output=True,
        text=True,
        timeout=30
    )
    print("STDOUT:", result.stdout)
    print("STDERR:", result.stderr)
    assert result.returncode == 0, f"BASE_ARROW_MIN_LENGTH constant test failed: {result.stderr}"


def test_updateBoundPoint_accepts_dragging_parameter():
    """Test that updateBoundPoint function signature accepts dragging parameter"""
    # Check that the function can be called with the dragging parameter
    code = """
const binding = require("@excalidraw/element/dist/binding.js");

// Check if updateBoundPoint exists
if (typeof binding.updateBoundPoint !== "function") {
    console.error("updateBoundPoint is not exported");
    process.exit(1);
}

// The fix changes the signature from opts?: { customIntersector? } to dragging?: boolean
// We can't easily call it without proper setup, but we can verify the module loads
// and the function exists with the right number of parameters

const fn = binding.updateBoundPoint;
console.log("updateBoundPoint parameter count:", fn.length);
// Function should accept 6 parameters (arrow, startOrEnd, binding, bindableElement, elementsMap, dragging)
if (fn.length < 5) {
    console.error("updateBoundPoint should accept at least 5 parameters");
    process.exit(1);
}
console.log("PASS: updateBoundPoint has correct signature");
"""
    result = subprocess.run(
        ["node", "-e", code],
        cwd=REPO,
        capture_output=True,
        text=True,
        timeout=30
    )
    print("STDOUT:", result.stdout)
    print("STDERR:", result.stderr)
    assert result.returncode == 0, f"updateBoundPoint signature test failed: {result.stderr}"


def test_extractBinding_function_exists():
    """Test that extractBinding helper function is implemented in binding.ts"""
    # This is a structural test but gated on compilation success
    # Check if the function exists in the source (it's a private function)
    binding_file = os.path.join(REPO, "packages/element/src/binding.ts")
    with open(binding_file, "r") as f:
        content = f.read()

    # The fix should add extractBinding function
    assert "const extractBinding = (" in content, "extractBinding function not found in binding.ts"
    assert "elementArea = (element" in content, "elementArea helper not found in binding.ts"


def test_no_indirectArrowUpdate_option():
    """Test that indirectArrowUpdate option is removed from updateBoundElements"""
    binding_file = os.path.join(REPO, "packages/element/src/binding.ts")
    with open(binding_file, "r") as f:
        content = f.read()

    # The fix should REMOVE indirectArrowUpdate option
    # Check that it no longer appears in the options type
    if "indirectArrowUpdate" in content:
        # If it exists, it should only be in comments or removed context
        lines = content.split("\n")
        for line in lines:
            if "indirectArrowUpdate" in line and not line.strip().startswith("//"):
                # Check if it's in the options type definition (bad)
                if "options?:" in line or "indirectArrowUpdate?:" in line:
                    assert False, "indirectArrowUpdate option still exists in updateBoundElements"


def test_imports_cleanup_in_binding():
    """Test that doBoundsIntersect and getElementBounds imports are removed from binding.ts"""
    binding_file = os.path.join(REPO, "packages/element/src/binding.ts")
    with open(binding_file, "r") as f:
        content = f.read()

    # The fix removes doBoundsIntersect and getElementBounds from imports
    # They should no longer be imported from ./bounds
    bounds_import_section = content[content.find('import {') : content.find('} from "./bounds";') + 18]

    assert "doBoundsIntersect" not in bounds_import_section, \
        "doBoundsIntersect should not be imported from ./bounds"
    assert "getElementBounds" not in bounds_import_section, \
        "getElementBounds should not be imported from ./bounds"


def test_align_ts_no_indirectArrowUpdate():
    """Test that align.ts no longer passes indirectArrowUpdate option"""
    align_file = os.path.join(REPO, "packages/element/src/align.ts")
    with open(align_file, "r") as f:
        content = f.read()

    # Check that indirectArrowUpdate is not passed
    assert "indirectArrowUpdate" not in content, \
        "align.ts should not reference indirectArrowUpdate"


def test_app_ts_no_indirectArrowUpdate():
    """Test that App.tsx no longer passes indirectArrowUpdate option"""
    app_file = os.path.join(REPO, "packages/excalidraw/components/App.tsx")
    with open(app_file, "r") as f:
        content = f.read()

