version: "2.0"

source:
  repo: "oven-sh/bun"
  pr: 28838
  base_commit: "5b3ca83b84f90ccc9c71005db0ab9bd87850bc70"
  merge_commit: "196ed8a1bd4d5c9915e71816ce64a6a281eee23e"
  title: "http: reject conflicting duplicate Content-Length headers"

checks:
  # Category 1: Code behavior tests (HTTP parser security fix)
  - id: http_parser_duplicate_check
    type: fail_to_pass
    origin: pr_diff
    description: "HttpParser.h must have logic to detect and reject duplicate Content-Length headers"

  - id: http_parser_empty_rejection
    type: fail_to_pass
    origin: pr_diff
    description: "HttpParser.h must reject empty Content-Length values (RFC 9112 6.3)"

  - id: http_parser_bloom_filter
    type: fail_to_pass
    origin: pr_diff
    description: "HttpParser.h should use bloom filter to short-circuit when no Content-Length present"

  - id: http_parser_400_error
    type: fail_to_pass
    origin: pr_diff
    description: "HttpParser.h must return HTTP 400 error when conflicting Content-Length headers detected"

  - id: http_parser_rfc_reference
    type: fail_to_pass
    origin: pr_diff
    description: "HttpParser.h must reference RFC 9112 6.3 in comments"

  # Category 2: Config/documentation update tests (REQUIRED for agentmd-edit)
  - id: claude_md_pr_feedback_section
    type: fail_to_pass
    origin: pr_diff
    description: "CLAUDE.md must have a 'Reading PR Feedback' section documenting the pr:comments command"

  - id: claude_md_pr_comments_command
    type: fail_to_pass
    origin: pr_diff
    description: "CLAUDE.md must document the 'bun run pr:comments' command"

  - id: claude_md_explains_footgun
    type: fail_to_pass
    origin: pr_diff
    description: "CLAUDE.md must explain the footgun with 'gh pr view --comments' omitting review comments"

  - id: claude_md_graphql_fields
    type: fail_to_pass
    origin: pr_diff
    description: "CLAUDE.md must document the JSON output fields including resolved/outdated thread state"

  - id: claude_md_usage_examples
    type: fail_to_pass
    origin: pr_diff
    description: "CLAUDE.md must have usage examples for the pr:comments command with jq filtering"

  - id: package_json_pr_comments_script
    type: fail_to_pass
    origin: pr_diff
    description: "package.json must have the 'pr:comments' script entry"

  - id: pr_comments_script_exists
    type: fail_to_pass
    origin: pr_diff
    description: "scripts/pr-comments.ts file must exist with the implementation"

  - id: pr_comments_pagination
    type: fail_to_pass
    origin: pr_diff
    description: "pr-comments.ts must handle pagination with --paginate flag"

  - id: pr_comments_all_endpoints
    type: fail_to_pass
    origin: pr_diff
    description: "pr-comments.ts must fetch all three endpoints: issues, pulls/reviews, pulls/comments"

# Track 2: Gold config edits (extracted deterministically from solve.sh)
config_edits:
  - path: "CLAUDE.md"
    tier: 1
    gold_added: "\n## Reading PR Feedback\n\n`gh pr view --comments` is fine for a quick look at the Conversation tab, but it has a footgun worth knowing about: it only returns issue-stream comments and silently omits review summaries and line-level review comments. If a reviewer leaves an inline comment on a specific file line, it will not show up — no error, no hint that anything is missing.\n\nWhen you want the complete picture — especially when responding to a review or checking whether anyone requested changes — use `bun run pr:comments`. It fetches all three GitHub endpoints (`/issues/N/comments`, `/pulls/N/reviews`, `/pulls/N/comments`) and prints them in one chronological listing, each labelled with its actual type (issue comment, review verdict, line comment, reply, suggestion block).\n\n```bash\nbun run pr:comments                    # current branch's PR\nbun run pr:comments 28838              # by PR number\nbun run pr:comments '#28838'           # also works\nbun run pr:comments https://github.com/oven-sh/bun/pull/28838\n\n# Machine-readable output for jq pipelines — one object per entry with\n# { when, user, kind, location?, body, url?, resolved?, outdated? }.\n# resolved/outdated come from GraphQL reviewThreads and are present only\n# on line comments / replies whose thread state was successfully fetched\n# (omitted on issue comments, review verdicts, and on GraphQL fetch\n# failure), so `resolved == false` unambiguously means \"confirmed open\n# thread\". No header, no truncation. The PR is optional here too\n# (defaults to the current branch's PR).\nbun run pr:comments --json | jq '.[] | select(.user == \"Jarred-Sumner\")'\nbun run pr:comments --json | jq '[.[] | select(.resolved == false)]'   # still open\n```"
    gold_removed: ""

  - path: "package.json"
    tier: 1
    gold_added: '    "pr:comments": "bun scripts/pr-comments.ts",'
    gold_removed: ""

# Track 3: Positive rubric — conventions the gold solution FOLLOWS
rubric:
  - rule: "Follow RFC 9112 6.3 for Content-Length header handling"
    source:
      path: "CLAUDE.md"
      lines: "1-50"
      commit: "5b3ca83b84f90ccc9c71005db0ab9bd87850bc70"
    evidence: "Gold fix implements RFC 9112 6.3: rejects multiple Content-Length headers with differing values, accepts duplicates with identical values"
    category: "security"
    verification: programmatic

  - rule: "Use bloom filter for performance optimization before iterating headers"
    source:
      path: "CLAUDE.md"
      lines: "1-50"
      commit: "5b3ca83b84f90ccc9c71005db0ab9bd87850bc70"
    evidence: "Gold code checks req->bf.mightHave() before the loop to short-circuit common 'no Content-Length' case"
    category: "performance"
    verification: programmatic

  - rule: "Add comprehensive documentation for new CLI commands in CLAUDE.md"
    source:
      path: "CLAUDE.md"
      lines: "1-50"
      commit: "5b3ca83b84f90ccc9c71005db0ab9bd87850bc70"
    evidence: "Gold patch adds detailed 'Reading PR Feedback' section with usage examples and jq pipelines"
    category: "documentation"
    verification: llm_judge

  - rule: "Handle pagination in GitHub API calls to avoid silent truncation"
    source:
      path: "CLAUDE.md"
      lines: "1-50"
      commit: "5b3ca83b84f90ccc9c71005db0ab9bd87850bc70"
    evidence: "Gold pr-comments.ts uses --paginate flag and manual GraphQL cursor loops for nested pagination"
    category: "correctness"
    verification: programmatic

  - rule: "Use strncmp with length check for efficient header name comparison"
    source:
      path: "CLAUDE.md"
      lines: "1-50"
      commit: "5b3ca83b84f90ccc9c71005db0ab9bd87850bc70"
    evidence: "Gold code compares header key length first (14), then uses strncmp for 'content-length' - efficient pattern"
    category: "performance"
    verification: programmatic

# Track 4: Distractors — conventions that create COLLISIONS
distractors:
  - rule: "Always use std::string instead of std::string_view for string handling"
    source:
      path: "CLAUDE.md"
      lines: "1-50"
      commit: "5b3ca83b84f90ccc9c71005db0ab9bd87850bc70"
    collision_type: "rule_conflict"
    why_distracting: "The gold solution intentionally uses std::string_view for zero-copy header value access - a distractor would suggest std::string which adds unnecessary allocation"
    severity: "medium"

  - rule: "Add all new scripts to package.json scripts section at the end"
    source:
      path: "package.json"
      lines: "1-50"
      commit: "5b3ca83b84f90ccc9c71005db0ab9bd87850bc70"
    collision_type: "scope_ambiguity"
    why_distracting: "Gold adds pr:comments in alphabetical position near other 'ci:*' scripts, not at the end - distractor suggests wrong placement"
    severity: "low"

  - rule: "Only document commands in README.md, not in CLAUDE.md"
    source:
      path: "CLAUDE.md"
      lines: "1-50"
      commit: "5b3ca83b84f90ccc9c71005db0ab9bd87850bc70"
    collision_type: "scope_ambiguity"
    why_distracting: "CLAUDE.md is specifically for agent instructions; documenting a new dev tool there is correct - distractor suggests wrong documentation target"
    severity: "medium"

  - rule: "Throw exceptions for error handling in TypeScript scripts"
    source:
      path: "CLAUDE.md"
      lines: "1-50"
      commit: "5b3ca83b84f90ccc9c71005db0ab9bd87850bc70"
    collision_type: "rule_conflict"
    why_distracting: "Gold pr-comments.ts uses process.exit() for CLI error handling, not exceptions - distractor suggests wrong pattern for CLI tools"
    severity: "medium"
