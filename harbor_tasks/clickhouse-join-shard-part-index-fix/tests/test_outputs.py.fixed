#!/usr/bin/env python3
"""
Test suite for ClickHouse optimizeJoinByShards fix.
Uses behavioral tests (code execution) where possible, with structural checks as fallback.
"""

import subprocess
import re
import json
import pytest
from pathlib import Path

REPO = Path("/workspace/ClickHouse")
TARGET_FILE = REPO / "src/Processors/QueryPlan/Optimizations/optimizeJoinByShards.cpp"


def _run_git(args, cwd=REPO, timeout=30):
    """Execute git command in the repo."""
    r = subprocess.run(
        ["git"] + args,
        capture_output=True, text=True, timeout=timeout, cwd=cwd,
    )
    return r


def _check_clang_syntax(file_path, timeout=60):
    """Check C++ syntax using clang -fsyntax-only if available."""
    r = subprocess.run(
        ["clang", "-fsyntax-only", "-std=c++20", "-xc++", str(file_path)],
        capture_output=True, text=True, timeout=timeout,
    )
    return r


def test_fix_part_index_renumbering():
    """
    Fail-to-pass: The fix must renumber part_index_in_query to be contiguous.

    BEFORE the fix:
      for (const auto & part : analysis_result->parts_with_ranges)
      {
          all_parts.push_back(part);
          all_parts.back().part_index_in_query += added_parts;
      }
    This was buggy because filterPartsByQueryConditionCache can drop parts,
    leaving gaps in indices. The += added_parts preserved those gaps.

    AFTER the fix:
      for (size_t local_idx = 0; local_idx < analysis_result->parts_with_ranges.size(); ++local_idx)
      {
          all_parts.push_back(analysis_result->parts_with_ranges[local_idx]);
          all_parts.back().part_index_in_query = added_parts + local_idx;
      }
    This creates contiguous indices starting from added_parts.
    """
    if not TARGET_FILE.exists():
        raise FileNotFoundError(f"Target file not found: {TARGET_FILE}")

    content = TARGET_FILE.read_text()

    # Check for the fix: should use local_idx loop variable
    has_indexed_loop = "for (size_t local_idx = 0;" in content

    # Check for the fix: should assign part_index_in_query = added_parts + local_idx
    has_correct_assignment = "part_index_in_query = added_parts + local_idx" in content

    # Check that old buggy pattern is NOT present
    old_pattern = "all_parts.back().part_index_in_query += added_parts"
    has_old_buggy_pattern = old_pattern in content

    # The fix must be present AND the old pattern must be absent
    assert has_indexed_loop, "Fix missing: should use indexed loop with local_idx"
    assert has_correct_assignment, "Fix missing: should assign part_index_in_query using local_idx"
    assert not has_old_buggy_pattern, f"Old buggy pattern still present: {old_pattern}"


def test_fix_compiles_syntax_only():
    """
    Fail-to-pass: The modified C++ code must have valid syntax.

    Uses clang -fsyntax-only to verify the code compiles without errors.
    This catches syntax errors, missing semicolons, mismatched braces, etc.
    """
    if not TARGET_FILE.exists():
        raise FileNotFoundError(f"Target file not found: {TARGET_FILE}")

    # Check if clang is available
    clang_check = subprocess.run(
        ["which", "clang"],
        capture_output=True, text=True, timeout=10,
    )

    if clang_check.returncode != 0:
        # Fallback: verify basic syntax via grep patterns
        content = TARGET_FILE.read_text()

        # The fix should have balanced braces in the modified for loop
        # Find the modified section and check for balanced braces
        lines = content.split('\n')
        fix_line_idx = None
        for i, line in enumerate(lines):
            if "for (size_t local_idx = 0" in line:
                fix_line_idx = i
                break

        if fix_line_idx is None:
            pytest.fail("Fix not found - cannot verify syntax")

        # Extract just the for loop body (approximately 5 lines: for, {, push, assign, })
        start = fix_line_idx
        end = min(len(lines), fix_line_idx + 5)
        block = '\n'.join(lines[start:end])

        # Check for balanced braces in the for loop body only
        open_count = block.count('{')
        close_count = block.count('}')

        # For the for loop body, we expect 1 opening brace and 1 closing brace
        # The closing brace might be on line 5 or later depending on formatting
        assert open_count >= 1, "No opening braces in fix block"
        assert close_count >= 1, "No closing braces in fix block"

        # Check for semicolons at end of statements
        assert ";" in block, "Missing semicolons in fix block"

        return

    # Use clang to check syntax
    r = _check_clang_syntax(TARGET_FILE)

    # Allow warnings but not errors
    if r.returncode != 0 and "error:" in r.stderr:
        # Filter only actual errors (not warnings)
        errors = [line for line in r.stderr.split('\n') if 'error:' in line.lower()]
        if errors:
            error_msg = '\n'.join(errors[:10])  # Show first 10 errors
            raise AssertionError(f"C++ syntax errors in target file:\n{error_msg}")


def test_fix_preserves_loop_semantics():
    """
    Fail-to-pass: The fix must preserve loop semantics - iterating all parts.

    The fix changes from range-for to index-for but must still:
    1. Iterate over ALL parts in analysis_result->parts_with_ranges
    2. Push each part to all_parts
    """
    if not TARGET_FILE.exists():
        raise FileNotFoundError(f"Target file not found: {TARGET_FILE}")

    content = TARGET_FILE.read_text()

    # The fix should still iterate over the full range
    has_full_range = "local_idx < analysis_result->parts_with_ranges.size()" in content

    # Should still push back all parts with correct indexing
    has_push_back = "all_parts.push_back(analysis_result->parts_with_ranges[local_idx])" in content

    assert has_full_range, "Loop should iterate over full range of parts"
    assert has_push_back, "All parts should be pushed to all_parts"


def test_fix_has_explanatory_comment():
    """
    Pass-to-pass: The fix should include explanatory comment about cache filtering.

    Per ClickHouse conventions, complex logic needs explanatory comments.
    The comment should explain WHY the fix is needed (filterPartsByQueryConditionCache
    dropping parts), not just WHAT it does.
    """
    if not TARGET_FILE.exists():
        raise FileNotFoundError(f"Target file not found: {TARGET_FILE}")

    content = TARGET_FILE.read_text()

    # Check for key phrases from the explanatory comment
    has_contiguous_comment = "contiguous" in content.lower()
    has_filter_comment = "filterPartsByQueryConditionCache" in content
    has_drop_comment = "drop parts" in content.lower() or "dropping parts" in content.lower()

    assert has_contiguous_comment, "Missing comment about contiguous indices"
    assert has_filter_comment, "Missing comment about filterPartsByQueryConditionCache"


def test_allman_brace_style():
    """
    Pass-to-pass: ClickHouse requires Allman-style braces (opening brace on new line).

    This is enforced by CI style check. The fix and surrounding code must follow this.
    """
    if not TARGET_FILE.exists():
        raise FileNotFoundError(f"Target file not found: {TARGET_FILE}")

    content = TARGET_FILE.read_text()
    lines = content.split('\n')

    # Find the modified section
    fix_line_idx = None
    for i, line in enumerate(lines):
        if "for (size_t local_idx = 0" in line:
            fix_line_idx = i
            break

    if fix_line_idx is None:
        pytest.skip("Fix not found - cannot check style")

    # Check the fix line and next line for Allman style
    # The for loop should have its opening brace on the next line
    for_line = lines[fix_line_idx].rstrip()
    next_line = lines[fix_line_idx + 1].strip() if fix_line_idx + 1 < len(lines) else ""

    # For loop should end with ) and brace should be on next line (Allman)
    assert for_line.endswith(")"), f"For loop should end with ): {for_line}"
    assert next_line == "{", f"Opening brace should be on its own line (Allman style), got: {next_line}"


def test_no_sleep_in_code():
    """
    Pass-to-pass: ClickHouse rule - never use sleep in C++ code to fix race conditions.

    Per CLAUDE.md: "Never use sleep in C++ code to fix race conditions"
    """
    if not TARGET_FILE.exists():
        raise FileNotFoundError(f"Target file not found: {TARGET_FILE}")

    content = TARGET_FILE.read_text()

    # Check for sleep functions
    sleep_patterns = [
        r'\bsleep\s*\(',
        r'\busleep\s*\(',
        r'\bstd::this_thread::sleep_for\b',
        r'\bstd::this_thread::sleep_until\b',
        r'\bSleep\s*\(',
    ]

    for pattern in sleep_patterns:
        matches = re.findall(pattern, content, re.IGNORECASE)
        assert len(matches) == 0, f"Found sleep in code (pattern: {pattern})"


def test_function_naming_convention():
    """
    Pass-to-pass: ClickHouse uses lowercase_with_underscores for variable names.

    Per CLAUDE.md: "Use lowercase_with_underscores for variable names"
    The fix introduces local_idx which follows this convention.
    """
    if not TARGET_FILE.exists():
        raise FileNotFoundError(f"Target file not found: {TARGET_FILE}")

    content = TARGET_FILE.read_text()

    # Check that the fix uses correct naming convention
    has_local_idx = "local_idx" in content
    has_added_parts = "added_parts" in content

    assert has_local_idx, "Fix should use local_idx (lowercase_with_underscores)"
    assert has_added_parts, "Fix should use added_parts (lowercase_with_underscores)"


def test_no_raw_pointers_in_fix():
    """
    Pass-to-pass: Check that the fix doesn't introduce raw pointer issues.

    Per AGENTS.md: "Raw pointers with unclear ownership are risky"
    The fix should use references, not raw pointers.
    """
    if not TARGET_FILE.exists():
        raise FileNotFoundError(f"Target file not found: {TARGET_FILE}")

    content = TARGET_FILE.read_text()
    lines = content.split('\n')

    # Find the modified section (around local_idx)
    fix_line_idx = None
    for i, line in enumerate(lines):
        if "local_idx = 0" in line:
            fix_line_idx = i
            break

    if fix_line_idx is None:
        pytest.skip("Fix not found - cannot check for raw pointers")

    # Check surrounding 20 lines for raw pointer declarations
    start = max(0, fix_line_idx - 20)
    end = min(len(lines), fix_line_idx + 20)
    modified_section = '\n'.join(lines[start:end])

    # Check for raw pointer declarations in modified section (excluding const char* which is common)
    raw_ptr_pattern = r'\b(?!const\s)(?!static\s)\w+\s*\*\s*\w+'
    raw_ptrs = re.findall(raw_ptr_pattern, modified_section)

    # Filter out false positives (analysis_result is a reference parameter)
    suspicious = [p for p in raw_ptrs if 'analysis_result' not in p]

    # The fix should not introduce new raw pointers
    assert len(suspicious) == 0, f"Suspicious raw pointer usage in fix: {suspicious}"


