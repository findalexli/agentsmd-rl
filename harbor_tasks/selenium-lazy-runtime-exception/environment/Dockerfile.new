FROM ubuntu:22.04

# Install dependencies: git, python3, curl, and build tools
RUN apt-get update && apt-get install -y \
    openjdk-21-jdk \
    git \
    python3 \
    python3-pip \
    curl \
    unzip \
    zip \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Bazelisk
RUN curl -Lo /usr/local/bin/bazelisk https://github.com/bazelbuild/bazelisk/releases/download/v1.22.0/bazelisk-linux-amd64 \
    && chmod +x /usr/local/bin/bazelisk \
    && ln -s /usr/local/bin/bazelisk /usr/local/bin/bazel

# Clone the repo at base commit
ARG BASE_COMMIT
RUN git clone --filter=blob:none https://github.com/SeleniumHQ/selenium.git /workspace/selenium \
    && cd /workspace/selenium \
    && git checkout ${BASE_COMMIT}

# Install pytest
RUN pip3 install pytest --break-system-packages 2>/dev/null || pip3 install pytest

# Create logs directory
RUN mkdir -p /logs/verifier

WORKDIR /workspace/selenium
